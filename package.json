{
  "name": "@vscode-use/treeprovider",
  "version": "0.0.5",
  "packageManager": "pnpm@7.33.7",
  "description": "A small helper for rendering VS Code TreeDataProvider views.",
  "author": "Simon He",
  "license": "MIT",
  "funding": "https://github.com/sponsors/Simon-He95",
  "homepage": "https://github.com/vscode-use/treeprovider#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vscode-use/treeprovider.git"
  },
  "bugs": "https://github.com/vscode-use/treeprovider/issues",
  "keywords": [
    "vscode",
    "treeview",
    "tree-data-provider",
    "vscode-extension"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "format": "prettier --write --cache .",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx,.md,.json --max-warnings 0 --cache",
    "lint:fix": "pnpm run lint --fix",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp && npm publish",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.25.2",
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.120.0",
    "bumpp": "^8.2.1",
    "eslint": "^8.18.0",
    "lint-staged": "^13.3.0",
    "picocolors": "^1.1.1",
    "prettier": "^2.8.8",
    "tsup": "^6.7.0",
    "tsx": "^3.14.0",
    "typescript": "^4.9.5",
    "vitest": "^0.15.2"
  },
  "lint-staged": {
    "*": [
      "prettier --write --cache --ignore-unknown"
    ],
    "*.{vue,js,ts,jsx,tsx,md,json}": "eslint --fix"
  },
  "eslintConfig": {
    "extends": "@antfu"
  }
}
