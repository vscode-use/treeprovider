{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/examples/example1"
      ],
      "outFiles": ["${workspaceFolder}/examples/example1/dist/**/*.js"],
      "preLaunchTask": "npm: dev - example1"
    }
  ]
}
